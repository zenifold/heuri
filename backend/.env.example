PORT=8787
HEURI_SHARED_SECRET=changeme

# AI_PROVIDER: "openrouter" (default) or "claude-code".
# "claude-code" uses a local `claude login` session instead of an API key —
# local/personal use only, see README "Using your Claude Pro/Max/Team subscription".
AI_PROVIDER=openrouter

OPENROUTER_API_KEY=sk-or-v1-...
# Free, vision-capable model for local/no-cost testing (rate-limited shared capacity).
# Swap to a paid model (e.g. anthropic/claude-sonnet-4.5) for real client deliverables.
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Only used when AI_PROVIDER=claude-code. Override if `claude` isn't on PATH.
# CLAUDE_CODE_BIN=claude

HEURI_TILE_TTL_MS=21600000
HEURI_PUBLIC_BASE_URL=http://localhost:8787
